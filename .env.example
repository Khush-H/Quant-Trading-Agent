# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# All secrets are read ONLY from environment variables (see config/settings.py).
# ---------------------------------------------------------------------------

# Run mode: backtest | paper | live   (default: paper)
MODE=paper

# LIVE TRADING SAFETY GATE.
# "live" mode refuses to start unless this is exactly "true".
# Leave false/unset for backtest and paper.
LIVE_TRADING_CONFIRMED=false

# --- Exchange API credentials (ccxt) ---------------------------------------
# Required for paper (read-only market data) and live trading.
EXCHANGE_ID=binance
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
# Some exchanges (e.g. coinbase, kucoin) need a passphrase; leave blank otherwise.
EXCHANGE_API_PASSWORD=
# Use the exchange's sandbox/testnet endpoint when available.
EXCHANGE_SANDBOX=true

# --- Database ---------------------------------------------------------------
# SQLite by default; swap for a full DSN (e.g. postgresql://...) in production.
DATABASE_URL=sqlite:///data/trading.db

# --- Risk limits (override defaults in config/settings.py) ------------------
MAX_POSITION_NOTIONAL=1000.0
MAX_DAILY_LOSS=200.0
MAX_OPEN_POSITIONS=5
MAX_LEVERAGE=1.0

# --- Web dashboard ----------------------------------------------------------
WEB_HOST=127.0.0.1
WEB_PORT=8000

# --- Misc -------------------------------------------------------------------
LOG_LEVEL=INFO
BASE_CURRENCY=USDT
